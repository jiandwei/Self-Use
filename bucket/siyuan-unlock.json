    "pre_install": [
        "7z x \"$dir\\`$PLUGINSDIR\\*.7z\" -o\"$dir\\`$PLUGINSDIR\\siyuan-unlock\"",
        "Remove-Item -R -Path $dir\\resources -ErrorAction SilentlyContinue",
        "Move-Item $dir\\`$PLUGINSDIR\\siyuan-unlock\\* $dir -force -ErrorAction SilentlyContinue",
        "Remove-Item -R -Path $dir\\`$PLUGINSDIR -ErrorAction SilentlyContinue",
        "Remove-Item -Path \"$dir\\resources\\pandoc.zip\" -ErrorAction SilentlyContinue",
        "Remove-Item -Path \"$dir\\resources\\changelogs\" -ErrorAction SilentlyContinue",
        "Remove-Item -Path \"$dir\\resources\\guide\" -ErrorAction SilentlyContinue",
        "Get-ChildItem \"$dir\\locales\" -Exclude \"zh-CN.pak\" | Remove-Item -Force -ErrorAction SilentlyContinue"
    ],
    "bin": "siyuan.exe",
    "shortcuts": [
        [
            "siyuan.exe",
            "Siyuan"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/appdev/siyuan-unlock/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
